<UserControl
    x:Class="SimpleJog.DockingWindow.Stick"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SimpleJog.DockingWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <Canvas Width="300" Height="300">

        <Canvas.Resources>
            <Style TargetType="Path">
                <Setter Property="Fill" Value="Black" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                        <Setter Property="Fill" Value="Gray" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Canvas.Resources>

        <Ellipse
            Canvas.Left="0"
            Canvas.Top="0"
            Width="300"
            Height="300"
            Fill="LightGray" />

        <Ellipse
            x:Name="KnobRange"
            Canvas.Left="70"
            Canvas.Top="70"
            Width="160"
            Height="160"
            Fill="White" />

        <Path
            Canvas.Left="130"
            Canvas.Top="30"
            Width="40"
            Height="40"
            Data="M 20,0 L 40,20 0,20 Z" />

        <Path
            Canvas.Left="30"
            Canvas.Top="130"
            Width="40"
            Height="40"
            Data="M 20,0 L 40,20 0,20 Z">
            <Path.RenderTransform>
                <RotateTransform Angle="-90" CenterX="20" CenterY="20" />
            </Path.RenderTransform>
        </Path>

        <Path
            Canvas.Left="130"
            Canvas.Top="230"
            Width="40"
            Height="40"
            Data="M 20,0 L 40,20 0,20 Z">
            <Path.RenderTransform>
                <RotateTransform Angle="180" CenterX="20" CenterY="20" />
            </Path.RenderTransform>
        </Path>

        <Path
            Canvas.Left="230"
            Canvas.Top="130"
            Width="40"
            Height="40"
            Data="M 20,0 L 40,20 0,20 Z">
            <Path.RenderTransform>
                <RotateTransform Angle="90" CenterX="20" CenterY="20" />
            </Path.RenderTransform>
        </Path>

        <Ellipse
            x:Name="Knob"
            Canvas.Left="100"
            Canvas.Top="100"
            Width="100"
            Height="100">
            <Ellipse.RenderTransform>
                <TranslateTransform X="{Binding RawPosition.X, RelativeSource={RelativeSource AncestorType=UserControl}}" Y="{Binding RawPosition.Y, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Ellipse.RenderTransform>
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Setter Property="Fill" Value="Red" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                            <Setter Property="Fill" Value="LightGray" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

    </Canvas>

</UserControl>
