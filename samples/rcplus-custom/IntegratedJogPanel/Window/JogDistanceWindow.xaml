<Window x:Class="IntegratedJogPanel.JogDistanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IntegratedJogPanel"
        xmlns:view="clr-namespace:IntegratedJogPanel.View"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Title="World Jog Distance" SizeToContent="Height" Width="520">
    <DockPanel Margin="8">
        <Grid DockPanel.Dock="Bottom" Margin="0 8 0 0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="_btnOK" Content="{Binding Path=[Common_OK].Value, Source={x:Static local:Main.Captions}}"/>
                <Button x:Name="_btnCancel" Content="{Binding Path=[Common_Cancel].Value, Source={x:Static local:Main.Captions}}" Margin="4 0 0 0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Reset" Visibility="Hidden"/>
            </StackPanel>
        </Grid>
        <WrapPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
            <WrapPanel.Resources>
                <Style TargetType="view:OnOffButton">
                    <Setter Property="Margin" Value="0 0 4 0"/>
                </Style>
            </WrapPanel.Resources>
            <view:OnOffButton x:Name="_onOffSpinInteger" LabelText="{Binding Path=[JogDistanceWin_SpinInteger].Value, Source={x:Static local:Main.Captions}}" SwitchOn="True"/>
            <view:OnOffButton x:Name="_onOffAccordDistanceMM" LabelText="{Binding Path=[JogDistanceWin_AccordMMDistance].Value, Source={x:Static local:Main.Captions}}" SwitchOn="True"/>
            <view:OnOffButton x:Name="_onOffAccordDistanceDeg" LabelText="{Binding Path=[JogDistanceWin_AccordDegDistance].Value, Source={x:Static local:Main.Captions}}" SwitchOn="True"/>
        </WrapPanel>
        <Grid x:Name="_grid" Margin="0 2 0 8">
            <Grid.Resources>
                <Style TargetType="TextBlock" x:Key="labelTxt">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
                <Style TargetType="Grid" x:Key="lineGrid">
                    <Setter Property="Background" Value="Gray"/>
                </Style>
                <Style TargetType="Grid" x:Key="labelGrid">
                    <Setter Property="Background" Value="#EEE"/>
                </Style>
                <Style TargetType="view:RealNumberEditControl">
                    <Setter Property="Margin" Value="5 4 0 4"/>
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>
            <Grid Style="{StaticResource labelGrid}" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="7"/>
            <Grid Style="{StaticResource labelGrid}" Grid.Column="1" Grid.Row="2" Grid.RowSpan="13"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="2" Grid.Row="0" Grid.ColumnSpan="7"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="9"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="9"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="9"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="8" Grid.ColumnSpan="9"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="10" Grid.ColumnSpan="9"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="12" Grid.ColumnSpan="9"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="14" Grid.ColumnSpan="9"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="0" Grid.Row="2" Grid.RowSpan="13"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="2" Grid.Row="0" Grid.RowSpan="15"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="4" Grid.Row="0" Grid.RowSpan="15"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="6" Grid.Row="0" Grid.RowSpan="15"/>
            <Grid Style="{StaticResource lineGrid}" Grid.Column="8" Grid.Row="0" Grid.RowSpan="15"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="Long" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="1" Grid.Column="5" Text="Medium" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="1" Grid.Column="7" Text="Short" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="_txtLabel1" Text="X" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="_txtLabel2" Text="Y" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="7" Grid.Column="1" x:Name="_txtLabel3" Text="Z" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="9" Grid.Column="1" x:Name="_txtLabel4" Text="U" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="11" Grid.Column="1" x:Name="_txtLabel5" Text="V" Style="{StaticResource labelTxt}"/>
            <TextBlock Grid.Row="13" Grid.Column="1" x:Name="_txtLabel6" Text="W" Style="{StaticResource labelTxt}"/>
        </Grid>
    </DockPanel>
</Window>
