<Window x:Class="IntegratedJogPanel.IOBitSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IntegratedJogPanel"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Title="I/O In Bit Select" Height="540" Width="700">
    <DockPanel Margin="8">
        <Grid Margin="0 0 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <DataGrid
                Grid.Column = "0"
                Grid.Row="1"
                x:Name="_dataGrid"
                IsReadOnly="True"
                AutoGenerateColumns="False"
                HorizontalGridLinesBrush="LightGray"
                VerticalGridLinesBrush="LightGray"
                HeadersVisibility="Column"
                VerticalScrollBarVisibility="Visible"
                SelectionMode="Single"
                CanUserAddRows="False"
                CanUserSortColumns="False"
                CanUserResizeRows="False">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#eee"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Padding" Value="4 1"/>
                        <Setter Property="BorderBrush" Value="LightGray"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="HAlignmentCenterStyle" TargetType="{x:Type TextBlock}" BasedOn="{x:Static DataGridTextColumn.DefaultElementStyle}">
                        <Setter Property="HorizontalAlignment" Value="Center" />
                    </Style>
                    <Style x:Key="HAlignmentRightStyle" TargetType="{x:Type TextBlock}" BasedOn="{x:Static DataGridTextColumn.DefaultElementStyle}">
                        <Setter Property="HorizontalAlignment" Value="Right" />
                    </Style>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#0078D7"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="50" Binding="{Binding BitNo}" Header="Bit" ElementStyle="{StaticResource HAlignmentCenterStyle}"/>
                    <DataGridTextColumn Width="*" Binding="{Binding Label}" Header="Label"/>
                    <DataGridTextColumn Width="2*" Binding="{Binding Description}" Header="Description"/>
                </DataGrid.Columns>
            </DataGrid>
            <Grid Grid.Column="1" Margin="8 00 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="1" x:Name="_stackPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 8"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0 8 0 8">
                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="36"/>
                            <Setter Property="Height" Value="40"/>
                        </Style>
                    </StackPanel.Resources>
                    <Button x:Name="_btnAdd" Content="Add"/>
                    <Button x:Name="_btnSet" Content="Set" Margin="4 0 0 0"/>
                    <Button x:Name="_btnClr" Content="Clr" Margin="4 0 0 0"/>
                    <Button x:Name="_btnClrAll" Content="Clr&#xa;All" Margin="4 0 0 0"/>
                    <Button x:Name="_btnLeft" Content="&lt;" Margin="4 0 0 0"/>
                    <Button x:Name="_btnRight" Content="&gt;" Margin="4 0 0 0"/>
                </StackPanel>
                <Grid Grid.Row="3" DockPanel.Dock="Bottom" Margin="0 4 0 0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="_btnOK" Content="{Binding Path=[Common_OK].Value, Source={x:Static local:Main.Captions}}"/>
                        <Button x:Name="_btnCancel" Content="{Binding Path=[Common_Cancel].Value, Source={x:Static local:Main.Captions}}" Margin="4 0 0 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="_btnReset" Content="{Binding Path=[Common_Reset].Value, Source={x:Static local:Main.Captions}}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
