<UserControl x:Class="IntegratedJogPanel.View.PlusMinusIntControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             mc:Ignorable="d" 
             d:DesignHeight="20" d:DesignWidth="100" HorizontalAlignment="Right">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Path x:Name="_mark" Data="M0,3 L6,3 M3,0 L3,6 M0,7 L6,7" Stroke="#333" StrokeThickness="1" Stretch="None" Margin="0 0 0 0" VerticalAlignment="Center" Visibility="Hidden"/>
        </Grid>
        <TextBlock Grid.Column="1" x:Name="_txtInt" Text="" FontSize="10" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
