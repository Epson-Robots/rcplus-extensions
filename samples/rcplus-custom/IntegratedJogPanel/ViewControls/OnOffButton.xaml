<UserControl x:Class="IntegratedJogPanel.View.OnOffButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             mc:Ignorable="d" 
             Height="20" d:DesignWidth="100" Name="root">
    <Grid Height="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" x:Name="_gridMark">
            <Ellipse x:Name="_ellipseL" Width="16" Height="16" Fill="#0078D7" HorizontalAlignment="Left"/>
            <Ellipse x:Name="_ellipseR" Width="16" Height="16" Fill="#0078D7" HorizontalAlignment="Right"/>
            <Rectangle  x:Name="_rectangle" Width="14" Height="16" Fill="#0078D7" HorizontalAlignment="Center"/>
            <Ellipse x:Name="_ellipseOff" Width="12" Height="12" Fill="White" HorizontalAlignment="Left" Margin="2 0 0 0"/>
            <Ellipse x:Name="_ellipseOn" Width="12" Height="12" Fill="White" HorizontalAlignment="Right" Margin="0 0 2 0"/>
        </Grid>
        <TextBlock Grid.Column="1" x:Name="_textBlockOnOff" FontSize="9" Text="Off" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="2 0 0 0"/>
        <TextBlock Grid.Column="2" x:Name="_textBlockLabel" Text="{Binding LabelText, ElementName=root}" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
