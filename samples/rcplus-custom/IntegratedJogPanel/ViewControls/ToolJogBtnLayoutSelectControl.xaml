<UserControl x:Class="IntegratedJogPanel.View.ToolJogBtnLayoutSelectControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="200">
    <Grid>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl0" Type="TwdZMinusXLeft"/>
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl1" Type="TwdZMinusXBottom"/>
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl2" Type="TwdZMinusXRight"/>
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl3" Type="TwdZMinusXTop"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 0">
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl4" Type="TwdZPlusXLeft"/>
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl5" Type="TwdZPlusXBottom"/>
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl6" Type="TwdZPlusXRight"/>
                <local:ToolJogBtnLayoutControl x:Name="_optCtrl7" Type="TwdZPlusXTop"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
