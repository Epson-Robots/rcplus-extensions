<UserControl x:Class="IntegratedJogPanel.View.RobotPointsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <DataGrid
            Grid.Row="1"
            x:Name="_dataGrid"
            IsReadOnly="False"
            AutoGenerateColumns="False"
            HorizontalGridLinesBrush="LightGray"
            VerticalGridLinesBrush="LightGray"
            HeadersVisibility="Column"
            VerticalScrollBarVisibility="Visible"
            SelectionMode="Single"
            CanUserAddRows="False"
            CanUserSortColumns="False"
            CanUserResizeRows="False">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#eee"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Padding" Value="4 1"/>
                    <Setter Property="BorderBrush" Value="LightGray"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
                <Style x:Key="HAlignmentCenterStyle" TargetType="{x:Type TextBlock}" BasedOn="{x:Static DataGridTextColumn.DefaultElementStyle}">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                </Style>
                <Style x:Key="HAlignmentRightStyle" TargetType="{x:Type TextBlock}" BasedOn="{x:Static DataGridTextColumn.DefaultElementStyle}">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                </Style>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#0078D7"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Width="64" Binding="{Binding Number}" Header="Number" ElementStyle="{StaticResource HAlignmentCenterStyle}" IsReadOnly="True"/>
                <DataGridTextColumn Width="2*" Binding="{Binding Label, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="Label*">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="MaxLength" Value="32" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Width="*" Binding="{Binding X, StringFormat={}{0:N3}, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="X*" ElementStyle="{StaticResource HAlignmentRightStyle}"/>
                <DataGridTextColumn Width="*" Binding="{Binding Y, StringFormat={}{0:N3}, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="Y*" ElementStyle="{StaticResource HAlignmentRightStyle}"/>
                <DataGridTextColumn Width="*" Binding="{Binding Z, StringFormat={}{0:N3}, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="Z*" ElementStyle="{StaticResource HAlignmentRightStyle}"/>
                <DataGridTextColumn Width="*" Binding="{Binding U, StringFormat={}{0:N3}, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="U*" ElementStyle="{StaticResource HAlignmentRightStyle}"/>
                <DataGridTextColumn Width="*" Binding="{Binding V, StringFormat={}{0:N3}, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="V*" ElementStyle="{StaticResource HAlignmentRightStyle}"/>
                <DataGridTextColumn Width="*" Binding="{Binding W, StringFormat={}{0:N3}, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="W*" ElementStyle="{StaticResource HAlignmentRightStyle}"/>
                <DataGridTextColumn Width="3.5*" Binding="{Binding PtFlags}" Header="/Hand/Elbow/Wrist/J1Flag/2Flag/4Flag/J6Flag" ElementStyle="{StaticResource HAlignmentCenterStyle}" IsReadOnly="True"/>
                <DataGridTextColumn Width="2*" Binding="{Binding Description, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}" Header="Description*">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="MaxLength" Value="256" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
