<UserControl x:Class="IntegratedJogPanel.View.JointControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             mc:Ignorable="d" d:DesignWidth="240">
    <Grid Margin="1">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Margin" Value="2 0"/>
                <Setter Property="FontSize" Value="10"/>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" x:Name="_txtBlockLabel" Text="J1" Margin="0" FontSize="12"/>
        <TextBlock Grid.Column="1" x:Name="_txtBlockMin" Text=""/>
        <Grid Grid.Column="2" Height="18" Margin="1 0 1 0" VerticalAlignment="Center">
            <Grid Margin="2 0" x:Name="_gridLine">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <Style TargetType="Line">
                        <Setter Property="Stroke" Value="Gray"/>
                        <Setter Property="StrokeThickness" Value="1"/>
                        <Setter Property="VerticalAlignment" Value="Bottom"/>
                    </Style>
                </Grid.Resources>
                <Line Y1="0" Y2="6" HorizontalAlignment="Left"/>
                <Line Y1="0" Y2="4" HorizontalAlignment="Center"/>
                <Line Y1="0" Y2="6" HorizontalAlignment="Right"/>
                <Grid Grid.Row="1" Height="1" Background="Gray"/>
            </Grid>
            <Path x:Name="_pathNeedle" Data="M1,7 L3,7 3,12 4,12 2,15 0,12 1,12 Z" Stroke="DimGray" Fill="Gray" StrokeThickness="1"/>
        </Grid>
        <TextBlock Grid.Column="3" x:Name="_txtBlockMax" Text=""/>
        <TextBlock Grid.Column="4" x:Name="_txtBlockCurrent" Text=""/>
        <local:PlusMinusIntControl Grid.Column="5" x:Name="_txtJogDistance"/>
        <Button Grid.Column="6" x:Name="_btnMinus" Content="-" Padding="0 -2 0 0"/>
        <Button Grid.Column="8" x:Name="_btnPlus" Content="+" Padding="0 -2 0 0"/>
    </Grid>
</UserControl>
