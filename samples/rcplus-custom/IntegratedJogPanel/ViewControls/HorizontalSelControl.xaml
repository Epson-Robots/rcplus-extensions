<UserControl x:Class="IntegratedJogPanel.View.HorizontalSelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="100">
    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="2" Background="Gray">
        <StackPanel x:Name="_stackPanel" Orientation="Horizontal">
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Width" Value="30"/>
                    <Setter Property="Height" Value="16"/>
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="TextAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </StackPanel.Resources>
        </StackPanel>
    </Border>
</UserControl>
