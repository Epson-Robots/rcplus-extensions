<UserControl x:Class="IntegratedJogPanel.View.TwoOptionSelButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="100" Margin="0 2">
    <Grid Height="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" x:Name="_gridMark">
            <Ellipse x:Name="_ellipseL" Width="18" Height="18" Fill="Gray" HorizontalAlignment="Left"/>
            <Ellipse x:Name="_ellipseR" Width="18" Height="18" Fill="Gray" HorizontalAlignment="Right"/>
            <Grid  x:Name="_rectangle" Height="18" Background="Gray" Margin="9 0 9 0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" x:Name="_gridA">
                    <Ellipse Width="14" Height="14" Fill="#0078D7" HorizontalAlignment="Right" Margin="0 0 -2 0"/>
                    <Ellipse Width="14" Height="14" Fill="#0078D7" HorizontalAlignment="Left" Margin="2 0 0 0"/>
                    <Grid Height="14" Background="#0078D7" Margin="9 0 4 0"/>
                </Grid>
                <Grid Grid.Column="1" x:Name="_gridB" Visibility="Hidden">
                    <Ellipse Width="14" Height="14" Fill="#0078D7" HorizontalAlignment="Left" Margin="-2 0 0 0"/>
                    <Ellipse Width="14" Height="14" Fill="#0078D7" HorizontalAlignment="Right" Margin="0 0 2 0"/>
                    <Grid Height="14" Background="#0078D7" Margin="4 0 9 0"/>
                </Grid>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                    </Style>
                </Grid.Resources>
                <TextBlock Grid.Column="0" x:Name="_txtA" Text="Low" Margin="0 -2 -4 0" Foreground="LightGray"/>
                <TextBlock Grid.Column="1" x:Name="_txtB" Text="High" Margin="-4 -2 0 0" Foreground="White"/>
            </Grid>
        </Grid>
        <TextBlock Grid.Column="1" x:Name="_textBlockLabel" Text="Foo" VerticalAlignment="Center" Margin="4 0 0 0"/>
    </Grid>
</UserControl>
