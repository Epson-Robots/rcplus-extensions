<UserControl x:Class="IntegratedJogPanel.View.JogItemPanelHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.View"
             xmlns:main="clr-namespace:IntegratedJogPanel"
             mc:Ignorable="d" 
             Height="18" d:DesignWidth="200" Background="#EFEFEF" Margin="0 0 0 4">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="#333"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>
        </Grid.Resources>
        <Grid Grid.Column="0" x:Name="_gridExpander" Width="14" Height="14" Margin="4 0 0 0" Background="Transparent">
            <Grid.Resources>
                <Style TargetType="Path">
                    <Setter Property="StrokeStartLineCap" Value="Round"/>
                    <Setter Property="StrokeEndLineCap" Value="Round"/>
                    <Setter Property="StrokeLineJoin" Value="Miter"/>
                </Style>
            </Grid.Resources>
            <Path x:Name="_markToOpen" Data="M3,5 L7,9 11,5" Stroke="#444" StrokeThickness="1" Stretch="None"/>
            <Path x:Name="_markToClose" Data="M3,9 L7,5 11,9" Stroke="#444" StrokeThickness="1" Stretch="None"/>
        </Grid>
        <TextBlock Grid.Column="1" x:Name="_txtTitle" Text="Hoge" Margin="8 0 0 0"/>
        <local:HorizontalSelControl Grid.Column="2" x:Name="_hSel" Height="16"/>
        <Button Grid.Column="3" x:Name="_btnEdit" Content="{Binding Path=[JogArea_Edit].Value, Source={x:Static main:Main.Captions}}" Height="18" Margin="3 0 2 0" FontSize="10"/>
    </Grid>
</UserControl>
