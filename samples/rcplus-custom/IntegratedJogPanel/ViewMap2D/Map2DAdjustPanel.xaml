<UserControl x:Class="IntegratedJogPanel.ViewMap2D.Map2DAdjustPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.ViewMap2D"
             xmlns:main="clr-namespace:IntegratedJogPanel"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <Grid x:Name="_grid" Width="800" Height="800" Background="Transparent">
        <Grid.Resources>
            <Style TargetType="Ellipse">
                <Setter Property="Stroke" Value="#300000FF"/>
            </Style>
        </Grid.Resources>
        <Ellipse Width="40" Height="40" StrokeThickness="4"/>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="_txtBlock" HorizontalAlignment="Center" Foreground="#C00000FF" VerticalAlignment="Top" FontSize="16" FontWeight="Bold" Text="A"/>
            <Button Grid.Row="1" x:Name="_btnChanage"  Content="{Binding Path=[ViewArea_AdujustModeChange].Value, Source={x:Static main:Main.Captions}}" Width="50"/>
        </Grid>
        <Line x:Name="_line" Stroke="#600000FF" StrokeThickness="6" X1="0" Y1="0" X2="400" Y2="400" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
    </Grid>
</UserControl>
