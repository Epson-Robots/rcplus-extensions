<UserControl x:Class="IntegratedJogPanel.ViewMap2D.Map2DPoint"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IntegratedJogPanel.ViewMap2D"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="Transparent">
    <Grid>
        <Ellipse x:Name="_circle" Width="20" Height="20" Fill="Red" StrokeThickness="1"/>
        <TextBlock x:Name="_txtBlock" HorizontalAlignment="Center" Text="A" VerticalAlignment="Center" Foreground="White" FontSize="12" FontWeight="Bold"/>
    </Grid>
</UserControl>
