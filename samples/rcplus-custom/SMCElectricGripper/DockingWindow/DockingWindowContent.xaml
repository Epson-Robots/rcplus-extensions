<UserControl
    x:Class="SMCElectricGripper.DockingWindow.DockingWindowContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:SMCElectricGripper.DockingWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <local:DockingWindowContentViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#D1D8E5" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ForceVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPositionMode.Value}" Value="True">
                    <Setter Property="Visibility" Value="Hidden" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NumericTextBoxStyle" TargetType="TextBox">
            <EventSetter Event="PreviewTextInput" Handler="NumericTextBox_PreviewTextInput" />
            <EventSetter Event="DataObject.Pasting" Handler="NumericTextBox_Pasting" />
            <EventSetter Event="LostFocus" Handler="NumericTextBox_LostFocus" />
            <EventSetter Event="KeyDown" Handler="NumericTextBox_KeyDown" />
        </Style>
        <Style x:Key="SwitchToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border
                                x:Name="Bg"
                                Background="#CCC"
                                CornerRadius="12" />
                            <Ellipse
                                x:Name="Knob"
                                Width="18"
                                Height="18"
                                Margin="2"
                                HorizontalAlignment="Left"
                                Fill="White" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#0078D7" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="Gray" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Left" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <local:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <ScrollViewer Background="White" VerticalScrollBarVisibility="Auto">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Connection Settings  -->
            <StackPanel Grid.Row="0">
                <StackPanel>
                    <Label
                        Content="{Binding Captions[ConnectionSettingsTitle].Value}"
                        FontSize="16"
                        FontWeight="UltraBold" />
                    <Border
                        HorizontalAlignment="Stretch"
                        BorderBrush="#6C757D"
                        BorderThickness="0,1,0,0" />
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="{Binding Captions[ConnectionPortLabel].Value}" />
                            <ComboBox
                                x:Name="PortComboBox"
                                Width="60"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding IsGripperConnected.Value, Converter={StaticResource InverseBoolConverter}}"
                                ItemsSource="{Binding ComPorts}"
                                SelectedItem="{Binding SelectedComPort.Value}" />
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <Button
                                x:Name="ConnectButton"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding ConnectCommand}"
                                Content="{Binding Captions[ConnectionButton].Value}"
                                IsEnabled="{Binding IsOperationReady.Value, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource ButtonStyle}" />
                            <Button
                                x:Name="DisconnectButton"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding DisconnectCommand}"
                                Content="{Binding Captions[DisconnectionButton].Value}"
                                IsEnabled="{Binding IsOperationReady.Value}"
                                Style="{StaticResource ButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!--  Motion Settings  -->
            <StackPanel
                Grid.Row="1"
                Margin="0,8,0,0"
                IsEnabled="{Binding IsOperationReady.Value}">
                <Label
                    Content="{Binding Captions[MotionSettingsTitle].Value}"
                    FontSize="16"
                    FontWeight="UltraBold" />
                <Border
                    HorizontalAlignment="Stretch"
                    BorderBrush="#6C757D"
                    BorderThickness="0,1,0,0" />
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Recipe No  -->
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Captions[RecipeNumberLabel].Value}" />
                    <ComboBox
                        x:Name="RecipeComboBox"
                        Grid.Row="0"
                        Grid.Column="1"
                        Width="50"
                        Margin="8,8,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                        ItemsSource="{Binding Recipes}"
                        SelectedItem="{Binding SelectedRecipe.Value}" />

                    <!--  Operation Mode  -->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,8,0,0"
                        VerticalAlignment="Top"
                        Text="{Binding Captions[OperationModeLabel].Value}" />
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="8,8,0,0"
                        Orientation="Vertical">
                        <RadioButton
                            x:Name="PositioningButton"
                            Content="{Binding Captions[PositioningRadioButton].Value}"
                            IsChecked="{Binding IsPositionMode.Value}"
                            IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}" />
                        <RadioButton
                            x:Name="GrippingButton"
                            Margin="0,8,0,0"
                            Content="{Binding Captions[GrippingRadioButton].Value}"
                            IsChecked="{Binding IsPositionMode.Value, Converter={StaticResource InverseBoolConverter}}"
                            IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>

                    <!--  Position  -->
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Captions[PositionLabel].Value}" />
                    <StackPanel
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="8,8,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBox
                            x:Name="PositionTextBox"
                            Width="40"
                            IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource NumericTextBoxStyle}"
                            Tag="{Binding PositionCommitCommand}"
                            Text="{Binding Position.Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                            TextAlignment="Right" />
                        <TextBlock Margin="8,0,0,0" Text="mm" />
                    </StackPanel>
                    <Slider
                        x:Name="PositionSlider"
                        Grid.Row="2"
                        Grid.Column="2"
                        Width="200"
                        Margin="8,8,0,0"
                        IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                        IsSnapToTickEnabled="True"
                        LargeChange="1.0"
                        Maximum="{Binding PositionMax.Value}"
                        Minimum="{Binding PositionMin.Value}"
                        SmallChange="0.1"
                        TickFrequency="0.1"
                        Value="{Binding Position.Value, Mode=TwoWay}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding PositionCommitCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Slider>

                    <!--  Speed  -->
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding Captions[SpeedLabel].Value}" />
                    <StackPanel
                        Grid.Row="3"
                        Grid.Column="1"
                        Margin="8,8,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBox
                            x:Name="SpeedTextBox"
                            Width="40"
                            IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource NumericTextBoxStyle}"
                            Tag="{Binding SpeedCommitCommand}"
                            Text="{Binding Speed.Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                            TextAlignment="Right" />
                        <TextBlock Margin="8,0,0,0" Text="mm/s" />
                    </StackPanel>
                    <Slider
                        x:Name="SpeedSlider"
                        Grid.Row="3"
                        Grid.Column="2"
                        Width="200"
                        Margin="8,8,0,0"
                        IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                        IsSnapToTickEnabled="True"
                        LargeChange="1.0"
                        Maximum="{Binding SpeedMax.Value}"
                        Minimum="{Binding SpeedMin.Value}"
                        SmallChange="0.1"
                        TickFrequency="0.1"
                        Value="{Binding Speed.Value, Mode=TwoWay}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding SpeedCommitCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Slider>

                    <!--  Force  -->
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="0"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource ForceVisibilityStyle}"
                        Text="{Binding Captions[ForceLabel].Value}" />
                    <StackPanel
                        Grid.Row="4"
                        Grid.Column="1"
                        Margin="8,8,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Style="{StaticResource ForceVisibilityStyle}">
                        <TextBox
                            x:Name="ForceTextBox"
                            Width="40"
                            IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                            Style="{StaticResource NumericTextBoxStyle}"
                            Tag="{Binding ForceCommitCommand}"
                            Text="{Binding Force.Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                            TextAlignment="Right" />
                        <TextBlock Margin="8,0,0,0" Text="N" />
                    </StackPanel>
                    <Slider
                        x:Name="ForceSlider"
                        Grid.Row="4"
                        Grid.Column="2"
                        Width="200"
                        Margin="8,8,0,0"
                        IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                        IsSnapToTickEnabled="True"
                        LargeChange="1.0"
                        Maximum="{Binding ForceMax.Value}"
                        Minimum="{Binding ForceMin.Value}"
                        SmallChange="0.1"
                        Style="{StaticResource ForceVisibilityStyle}"
                        TickFrequency="0.1"
                        Value="{Binding Force.Value, Mode=TwoWay}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding ForceCommitCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Slider>
                </Grid>
                <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                    <Button
                        x:Name="BackupButton"
                        HorizontalAlignment="Left"
                        Command="{Binding BackupSettingsCommand}"
                        Content="{Binding Captions[BackupSettingsButton].Value}"
                        IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource ButtonStyle}" />
                    <Button
                        x:Name="RestoreButton"
                        Margin="8,0,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding RestoreSettingsCommand}"
                        Content="{Binding Captions[RestoreSettingsButton].Value}"
                        IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource ButtonStyle}" />
                </StackPanel>
            </StackPanel>

            <!--  Run  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,8,0,0"
                IsEnabled="{Binding IsOperationReady.Value}">
                <Label
                    Content="{Binding Captions[RunTitle].Value}"
                    FontSize="16"
                    FontWeight="UltraBold" />
                <Border
                    HorizontalAlignment="Stretch"
                    BorderBrush="#6C757D"
                    BorderThickness="0,1,0,0" />
                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                    <Grid Margin="8,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="{Binding Captions[ServoLabel].Value}" />
                            <ToggleButton
                                x:Name="ServoButton"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding ServoCommand}"
                                IsChecked="{Binding IsServoOn.Value}"
                                IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource SwitchToggleButtonStyle}" />
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServoOn.Value}" Value="True">
                                                <Setter Property="Text" Value="ON" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Orientation="Horizontal">
                            <Button
                                x:Name="ExecuteButton"
                                Command="{Binding ExecuteCommand}"
                                Content="{Binding Captions[ExecuteButton].Value}"
                                Style="{StaticResource ButtonStyle}" />
                            <Button
                                x:Name="AbortButton"
                                Margin="8,0,0,0"
                                Command="{Binding AbortCommand}"
                                Content="{Binding Captions[AbortButton].Value}"
                                Style="{StaticResource ButtonStyle}" />
                        </StackPanel>
                        <StackPanel
                            Grid.Row="2"
                            Margin="0,8,0,0"
                            Orientation="Horizontal">
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding Captions[JogLabel].Value}" />
                            <Button
                                x:Name="OpenButton"
                                Margin="8,0,0,0"
                                Content="{Binding Captions[OpenButton].Value}"
                                IsEnabled="{Binding CanOpen.Value}"
                                Style="{StaticResource ButtonStyle}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding OpenStartCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding JogAbortCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                            <Button
                                x:Name="CloseButton"
                                Margin="8,0,0,0"
                                Content="{Binding Captions[CloseButton].Value}"
                                IsEnabled="{Binding CanClose.Value}"
                                Style="{StaticResource ButtonStyle}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding CloseStartCommand}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding JogAbortCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="32,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{Binding Captions[StatusLabel].Value}" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Width="140"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding Status.Value}"
                                TextAlignment="Left" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{Binding Captions[CurrentPositionLabel].Value}" />
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="40"
                                    Margin="8,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding CurrentPosition.Value, StringFormat=F1}"
                                    TextAlignment="Right" />
                                <TextBlock
                                    Margin="8,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="mm" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <Button
                                x:Name="RefreshButton"
                                Command="{Binding RefreshCommand}"
                                Content="{Binding Captions[RefreshStatusButton].Value}"
                                IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource ButtonStyle}" />
                            <Button
                                x:Name="ResetButton"
                                Margin="8,0,0,0"
                                Command="{Binding ResetCommand}"
                                Content="{Binding Captions[ResetButton].Value}"
                                IsEnabled="{Binding IsOperating.Value, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource ButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

