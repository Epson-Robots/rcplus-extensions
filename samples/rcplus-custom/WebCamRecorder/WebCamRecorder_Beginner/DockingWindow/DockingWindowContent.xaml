<UserControl
    x:Class="WebCamRecorder.DockingWindow.DockingWindowContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:WebCamRecorder.DockingWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <local:DockingWindowContentViewModel />
    </UserControl.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">

        <DockPanel Background="White" LastChildFill="True">

            <StackPanel
                Margin="10"
                DockPanel.Dock="Top"
                Orientation="Horizontal">

                <Label Content="{Binding Captions[CaptionCamera].Value}" />
                <ComboBox
                    MinWidth="100"
                    Margin="10,0,0,0"
                    DisplayMemberPath="FriendlyName"
                    IsReadOnly="True"
                    ItemsSource="{Binding Cameras}"
                    SelectedIndex="{Binding SelectedCameraIndex.Value}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="DropDownOpened">
                            <i:InvokeCommandAction Command="{Binding RefreshCamerasCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ComboBox>

            </StackPanel>

            <Image
                x:Name="PreviewImage"
                Width="640"
                Height="480"
                HorizontalAlignment="Left"
                Stretch="UniformToFill" />

        </DockPanel>
    </ScrollViewer>

</UserControl>
